# =============================================================================
# WriterAgent 环境变量示例
# -----------------------------------------------------------------------------
# 使用方式：复制为 .env 后按需修改（本地工具若读 .env，请先安装 python-dotenv 或自行 export）
# 说明均为简体中文；默认值以代码中 runtime_config 为准，此处仅作释义与典型取值参考。
# =============================================================================

# ----------------------------------------------------------------------------- 
# 运行环境与数据库
# ----------------------------------------------------------------------------- 
# 部署环境标记：设为 production 时，未配置 DATABASE_URL 会拒绝启动（防误用默认库）
# WRITER_ENV=development

# PostgreSQL 连接串（SQLAlchemy URL）
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/writer_agent_db

# 为 1/true/yes 时打印 SQL（调试用）
# SQL_ECHO=0

# ----------------------------------------------------------------------------- 
# 主文本 LLM（章节写作、一致性、修订等共用，见 TextGenerationRuntimeConfig）
# ----------------------------------------------------------------------------- 
# OpenAI 兼容 API 根路径（勿尾斜杠）；通义示例：https://dashscope.aliyuncs.com/compatible-mode/v1
# WRITER_LLM_BASE_URL=https://api.openai.com/v1

# API Key（Bearer）
# WRITER_LLM_API_KEY=

# 模型名
# WRITER_LLM_MODEL=qwen-plus

# HTTP 读超时（秒，1~900）；可与 WRITER_LLM_TIMEOUT_USE_PROFILE_FLOOR 叠加厂商建议下限
# WRITER_LLM_TIMEOUT=60

# 单次 completion 的 max_tokens 硬上限（可选）。不设则对 DashScope 等使用 registry 默认（如 8192）；设则覆盖 profile
# WRITER_LLM_MAX_OUTPUT_TOKENS=8192

# 兼容模式：auto | full（json_schema+强制工具）| basic（json_object+提示词带 schema）
# WRITER_LLM_COMPAT_MODE=auto

# 为 true 时：实际超时 = max(WRITER_LLM_TIMEOUT, 厂商 registry 的 default_timeout)
# WRITER_LLM_TIMEOUT_USE_PROFILE_FLOOR=true

# 修订工作流（writer_revision）单次 LLM HTTP 读超时（秒，1~900）；不设则仅用上述全局超时。长章节修订可设 480~600
# WRITER_REVISION_LLM_TIMEOUT=

# Prompt 超长时的「整段压缩」守卫（见 openai_compatible）
# WRITER_LLM_PROMPT_GUARD_ENABLED=true
# WRITER_LLM_CONTEXT_WINDOW_TOKENS=128000
# WRITER_LLM_PROMPT_GUARD_OUTPUT_RESERVE_TOKENS=4096
# WRITER_LLM_PROMPT_GUARD_OVERHEAD_TOKENS=256
# WRITER_LLM_PROMPT_GUARD_MAX_ATTEMPTS=2
# WRITER_LLM_PROMPT_GUARD_LLM_MAX_INPUT_CHARS=32000

# 是否将每次 LLM 请求的 system/user 落库并在日志中输出 llm_task_id（默认 true；需 DATABASE_URL + migration）
# WRITER_LLM_PROMPT_AUDIT_ENABLED=true

# 管理员 GET /v2/system/llm-prompts/{id} 在 DB 无行时是否读取仓库 data/llm_prompt_audit.jsonl（默认 true）
# WRITER_LLM_PROMPT_AUDIT_API_JSONL_FALLBACK=true

# ----------------------------------------------------------------------------- 
# 章节生成字数与 schema 软约束（见 chapter_generation/service、chapter_metrics）
# ----------------------------------------------------------------------------- 
# 按 target_words 估算章节 JSON 输出 max_tokens 时的全局上界（与 WRITER_LLM_MAX_OUTPUT_TOKENS 不同：后者为网关硬顶）
# WRITER_CHAPTER_MAX_OUTPUT_TOKENS_CAP=32000

# 字数未达标时的最大重试轮数（1~10，默认 3）
# WRITER_CHAPTER_WORD_COUNT_MAX_ATTEMPTS=3

# 偏短时是否启用「短文扩写」模式（1/0）
# WRITER_CHAPTER_TOO_SHORT_EXPAND_ENABLED=1

# 从第几轮开始允许短文扩写（≥2，默认 3）
# WRITER_CHAPTER_TOO_SHORT_EXPAND_TRIGGER_ATTEMPT=3

# schema 中 content.minLength 是否随轮次递减（1/0，默认 1）
# WRITER_CHAPTER_SCHEMA_MIN_PROGRESSIVE=1

# 多轮仍不达标是否用最后一稿放行（1/0，默认 1）
# WRITER_CHAPTER_WORD_COUNT_FINAL_BYPASS=1

# schema 校验失败时是否下调 minLength（排障用，默认关）
# WRITER_CHAPTER_SCHEMA_MIN_RELAX_ON_FAIL=0
# WRITER_CHAPTER_SCHEMA_MIN_RELAX_FACTOR=0.75

# content.minLength 相对业务低线的软比例与绝对比例（见 _schema_min_content_len_for_attempt）
# WRITER_CHAPTER_SCHEMA_CONTENT_SOFT_MIN_RATIO=0.58
# WRITER_CHAPTER_SCHEMA_SOFT_ABS_FRAC=0.22

# ----------------------------------------------------------------------------- 
# 一致性审查（consistency_review / ConsistencyReviewWorkflowService）
# ----------------------------------------------------------------------------- 
# 为 true 时：LLM 使用多轮 chat/completions，注册 fetch_consistency_evidence + consistency_review_output（tool_choice=auto，适合 DashScope 等）
# 为 false：保持单轮 generate + 强制输出函数（默认）。主路径已是 review_context + review_evidence_pack；tool loop 仅作证据仍不足或厂商/排障时的溢出补证，非常态。
# WRITER_CONSISTENCY_REVIEW_TOOL_LOOP=false

# （可选，未实现自动触发）仅在 schema 修复失败时再尝试 tool loop 时启用；当前仍以显式 WRITER_CONSISTENCY_REVIEW_TOOL_LOOP 为准
# WRITER_CONSISTENCY_REVIEW_TOOL_LOOP_ON_SCHEMA_MISS=false

# 多轮 tool loop 下 fetch_consistency_evidence 的最大拉库次数（1~20，默认 3）
# WRITER_CONSISTENCY_REVIEW_MAX_FETCHES=3

# 多轮 tool loop 下单次 HTTP 读超时：若设置 WRITER_REVISION_LLM_TIMEOUT，则优先使用该值（与修订链路一致）；否则沿用 Provider 全局读超时

# 为 true（默认）时：fetch_consistency_evidence 仅允许拉取已出现在 review_context / review_evidence_pack 的 entity_id
# WRITER_CONSISTENCY_REVIEW_STRICT_ENTITY_FETCH=true

# ----------------------------------------------------------------------------- 
# 章节生成 story_assets（见 build_story_assets_from_context）
# ----------------------------------------------------------------------------- 
# 为 true（默认）时：writer payload 中 chapters/characters/world 等为摘要视图；为 false 时保持 context_provider 原始列表形态（仍受 DB limit）
# WRITER_STORY_ASSETS_SUMMARY_FIRST=true

# 为 true（默认）时：章节生成从 DB 拉 story 上下文优先按「写作目标 + 编排 alignment」文本命中实体（load_focused），否则回退宽池子集；为 false 时始终用 load() 固定上限候选池
# WRITER_STORY_CONTEXT_LOAD_FOCUS=true

# ----------------------------------------------------------------------------- 
# 编排 Worker / Agent / Schema / Skill（见 OrchestratorRuntimeConfig）
# ----------------------------------------------------------------------------- 
# WRITER_WORKER_ID=
# WRITER_ORCH_WORKER_POLL_INTERVAL=1.0
# WRITER_ORCH_WORKER_BATCH_SIZE=3
# WRITER_ORCH_MAX_STEP_SECONDS=300
# WRITER_ORCH_RUN_INITIAL_LEASE_SECONDS=900
# WRITER_ORCH_RUN_LEASE_EXTEND_SECONDS=900
# WRITER_ORCH_RECOVER_HEARTBEAT_STALE_SECONDS=900
# WRITER_ORCH_ENABLE_STARTUP_LEASE_RECOVER=true
# WRITER_ORCH_DEFAULT_MAX_RETRIES=2
# WRITER_ORCH_DEFAULT_RETRY_DELAY=30
# WRITER_ORCH_ENABLE_AUTO_WORKER=true

# Agent / Schema / Skill 根目录（相对仓库根）
# WRITER_AGENT_CONFIG_ROOT=apps/agents
# WRITER_SCHEMA_ROOT=packages/schemas
# WRITER_SKILL_CONFIG_ROOT=packages/skills

# WRITER_SCHEMA_STRICT=true
# WRITER_SCHEMA_DEGRADE_MODE=false
# WRITER_SCHEMA_CONSUMPTION_STRICT=false
# WRITER_SCHEMA_CONSUMPTION_DEGRADE_MODE=false

# WRITER_SKILL_RUNTIME_FAIL_OPEN=true
# WRITER_SKILL_RUNTIME_STRICT_FAIL_CLOSE=false
# WRITER_SKILL_RUNTIME_DEFAULT_EXECUTION_MODE=active
# WRITER_SKILL_RUNTIME_DEFAULT_FALLBACK_POLICY=warn_only
# WRITER_SKILL_RUNTIME_REQUIRE_EFFECT_TRACE=true

# 检索回路 / 写作评测开关（编排侧）
# WRITER_EVAL_ONLINE_ENABLED=true
# WRITER_EVAL_DAILY_CRON=0 2 * * *
# WRITER_RETRIEVAL_MAX_ROUNDS=20
# WRITER_RETRIEVAL_ROUND_TOP_K=8
# WRITER_RETRIEVAL_MAX_UNIQUE_EVIDENCE=64
# WRITER_RETRIEVAL_STOP_MIN_COVERAGE=0.85
# WRITER_RETRIEVAL_STOP_MIN_GAIN=0.05
# WRITER_RETRIEVAL_STOP_STALE_ROUNDS=2

# WRITER_WORKFLOW_RUN_TIMEOUT_SECONDS=900
# WRITER_CONTEXT_CHAPTER_WINDOW_BEFORE=2
# WRITER_CONTEXT_CHAPTER_WINDOW_AFTER=1

# WRITER_API_V1_ENABLED=false
# WRITER_LIFECYCLE_ENABLED=false
# WRITER_LIFECYCLE_EMBEDDING_LIMIT=200
# WRITER_LIFECYCLE_REBUILD_LIMIT=200
# WRITER_LIFECYCLE_FORGET_LIMIT=200
# WRITER_LIFECYCLE_FORGET_DRY_RUN=true

# 章节候选（待审）过期小时数
# WRITER_REVIEW_EXPIRE_HOURS=72

# WRITER_WEBHOOK_ENABLED=true
# WRITER_WEBHOOK_BATCH_SIZE=50

# ----------------------------------------------------------------------------- 
# 动态规划器（独立 LLM，见 PlannerRuntimeConfig）
# ----------------------------------------------------------------------------- 
# WRITER_PLANNER_USE_MOCK=false
# WRITER_PLANNER_FALLBACK_TO_MOCK=true
# WRITER_PLANNER_MODEL=mock-planner-v1
# WRITER_PLANNER_BASE_URL=https://api.openai.com/v1
# WRITER_PLANNER_API_KEY=
# WRITER_PLANNER_TEMPERATURE=0.2
# WRITER_PLANNER_TIMEOUT=20

# ----------------------------------------------------------------------------- 
# 检索管线（详见 packages/retrieval/config.py — RetrievalRuntimeConfig.from_env）
# ----------------------------------------------------------------------------- 
# WRITER_RETRIEVAL_TOP_K=8
# WRITER_RETRIEVAL_AB_TEST_ENABLED=false
# WRITER_RETRIEVAL_AB_TEST_B_RATIO=0.5
# WRITER_RETRIEVAL_MAX_DISTANCE=
# WRITER_RETRIEVAL_FALLBACK_MAX_DISTANCE=
# WRITER_RETRIEVAL_ADAPTIVE_FALLBACK_FLOOR=0.35
# WRITER_RETRIEVAL_ENABLE_QUERY_REWRITE=false
# WRITER_RETRIEVAL_ENABLE_HYBRID=true
# WRITER_RETRIEVAL_ENABLE_RERANK=true
# WRITER_RETRIEVAL_QUERY_REWRITE_BACKEND=rule
# WRITER_RETRIEVAL_KEYWORD_BACKEND=sql_bm25
# WRITER_RETRIEVAL_FUSION_BACKEND=rrf
# WRITER_RETRIEVAL_HYBRID_BACKEND=pipeline
# WRITER_RETRIEVAL_CANDIDATE_MULTIPLIER=4
# WRITER_RETRIEVAL_RRF_K=60
# WRITER_RETRIEVAL_HYBRID_VECTOR_WEIGHT=0.65
# WRITER_RETRIEVAL_HYBRID_KEYWORD_WEIGHT=0.35
# WRITER_RETRIEVAL_RERANK_BACKEND=cross_encoder
# WRITER_RETRIEVAL_RERANK_VECTOR_WEIGHT=0.5
# WRITER_RETRIEVAL_RERANK_KEYWORD_WEIGHT=0.2
# WRITER_RETRIEVAL_RERANK_RECENCY_WEIGHT=0.2
# WRITER_RETRIEVAL_RERANK_CANONICAL_FACT_BOOST=0.1
# WRITER_RERANK_SERVICE_BASE_URL=
# WRITER_RERANK_SERVICE_API_KEY=
# WRITER_RERANK_SERVICE_MODEL=
# WRITER_RERANK_SERVICE_TIMEOUT=8.0
# WRITER_RETRIEVAL_VECTOR_BACKEND=pgvector
# WRITER_RETRIEVAL_VECTOR_DIM=1024
# WRITER_RETRIEVAL_FAISS_METRIC=l2
# WRITER_RETRIEVAL_MILVUS_URI=
# WRITER_RETRIEVAL_MILVUS_COLLECTION=
# WRITER_RETRIEVAL_QDRANT_URL=
# WRITER_RETRIEVAL_QDRANT_COLLECTION=

# 关键词候选条数上限（search_service）
# WRITER_RETRIEVAL_KEYWORD_CANDIDATE_LIMIT=1200

# 检索 embedding 是否用缓存
# WRITER_RETRIEVAL_EMBED_USE_CACHE=0

# ----------------------------------------------------------------------------- 
# 长期记忆 / 摄入（见 packages/memory/long_term/runtime_config.py）
# ----------------------------------------------------------------------------- 
# WRITER_MEMORY_CHUNK_SIZE=1200
# WRITER_MEMORY_CHUNK_OVERLAP=200
# WRITER_MEMORY_INGEST_EMBEDDING_BATCH_SIZE=8
# WRITER_MEMORY_INGEST_REPLACE_EXISTING_BY_DEFAULT=true
# WRITER_MEMORY_SEMANTIC_DEDUP_THRESHOLD=0.92
# WRITER_MEMORY_SUMMARY_TARGET_TOKENS=256
# WRITER_MEMORY_LOGGER_NAME=writeragent.memory
# WRITER_MEMORY_ENABLE_LOGGING=true
# WRITER_MEMORY_CONTEXT_COMPRESS_ENABLE_LLM=false
# WRITER_MEMORY_CONTEXT_COMPRESS_LLM_TRIGGER_RATIO=0.82
# WRITER_MEMORY_CONTEXT_COMPRESS_LLM_MIN_GAIN_RATIO=0.08
# WRITER_MEMORY_CONTEXT_COMPRESS_LLM_MAX_INPUT_CHARS=12000
# WRITER_MEMORY_CONTEXT_COMPRESS_LLM_MAX_ITEMS=24
# WRITER_MEMORY_CONTEXT_TOKEN_BUDGET_DEFAULT=8192
# WRITER_MEMORY_CONTEXT_MIN_RELEVANCE_SCORE=0.18
# WRITER_MEMORY_CONTEXT_RELATIVE_SCORE_FLOOR=0.55
# WRITER_MEMORY_CONTEXT_MIN_KEEP_ROWS=6
# WRITER_MEMORY_CONTEXT_MAX_ROWS=48
# WRITER_MEMORY_FORGET_ENABLE=true
# WRITER_MEMORY_FORGET_COOLING_DAYS=7
# WRITER_MEMORY_FORGET_SUPPRESS_DAYS=30
# WRITER_MEMORY_FORGET_ARCHIVE_DAYS=90
# WRITER_MEMORY_FORGET_DELETE_DAYS=180
# WRITER_MEMORY_FORGET_MIN_MENTION_KEEP=3
# WRITER_MEMORY_FORGET_RUN_LIMIT=200

# ----------------------------------------------------------------------------- 
# Embedding 服务（与 WRITER_LLM_* 独立，见 packages/llm/embeddings/factory.py）
# ----------------------------------------------------------------------------- 
# WRITER_EMBEDDING_PROVIDER=local_api

# EMBEDDING_SERVICE_BASE_URL=http://127.0.0.1:8000
# EMBEDDING_API_KEY=dummy-key
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_FORWARD_BASE_URL=

# ----------------------------------------------------------------------------- 
# 认证（见 packages/auth/runtime_config.py）
# ----------------------------------------------------------------------------- 
# WRITER_AUTH_JWT_SECRET=dev-insecure-jwt-secret-change-me
# WRITER_AUTH_JWT_ISSUER=writeragent
# WRITER_AUTH_ACCESS_TTL_MINUTES=15
# WRITER_AUTH_REFRESH_TTL_DAYS=30
# WRITER_AUTH_ENFORCE_PROD_SECRET=true

# ----------------------------------------------------------------------------- 
# Next.js BFF（apps/web）
# ----------------------------------------------------------------------------- 
# 后端 API 基址（勿尾斜杠）；不填则 BFF 会探测 8080/8000
# BACKEND_BASE_URL=http://127.0.0.1:8080

# ----------------------------------------------------------------------------- 
# 发布门禁脚本（scripts/release_gate.py，可选）
# ----------------------------------------------------------------------------- 
# WRITER_GATE_MAX_EMPTY_RESULT_RATE=0.35
# WRITER_GATE_MIN_FALLBACK_HIT_RATE=0.02
# WRITER_GATE_MAX_EMBEDDING_FAILURE_RATE=0.05
# WRITER_GATE_MAX_RETRIEVAL_P95_MS=1500.0
# WRITER_GATE_MIN_RETRIEVAL_REPLAY_COMPLETENESS=0.95
# WRITER_GATE_MIN_EVIDENCE_COVERAGE=0.80
# WRITER_GATE_MAX_CONSISTENCY_CONFLICT_RATE=0.30
# WRITER_GATE_MIN_REVISION_GAIN_RATE=0.05
# WRITER_GATE_MIN_BACKUP_LAST_SUCCESS=1.0
# WRITER_GATE_MIN_RESTORE_DRILL_LAST_SUCCESS=1.0
