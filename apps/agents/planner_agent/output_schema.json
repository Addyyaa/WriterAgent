{
  "type": "object",
  "properties": {
    "plan_summary": {
      "type": "string",
      "description": "用一句话概括整个计划的逻辑流"
    },
    "global_required_slots": {
      "type": "array",
      "description": "全计划通用的信息槽位（snake_case，与检索循环 must_have_slots 对齐；可为空）",
      "items": { "type": "string" }
    },
    "global_preferred_tools": {
      "type": "array",
      "description": "全计划优先调用的工具名（如 character_inventory、project_memory_search；可为空）",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "description": "3-7 个原子化执行步骤",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "step_id": { "type": "integer" },
          "name": { "type": "string" },
          "instruction": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "risk_item": { "type": "string" },
          "fallback_strategy": { "type": "string" },
          "required_slots": {
            "type": "array",
            "description": "本步写作前检索应覆盖的槽位（snake_case，如 character_inventory、power_rules）",
            "items": { "type": "string" }
          },
          "must_verify_facts": {
            "type": "array",
            "description": "动笔前必须核验的事实陈述（供审校/检索侧重，可为空）",
            "items": { "type": "string" }
          },
          "fallback_when_missing": {
            "type": "string",
            "description": "关键信息缺失时的处理原则（如：标记待补设定，不写死为既成事实）"
          },
          "preferred_tools": {
            "type": "array",
            "description": "本步优先使用的结构化工具或检索工具标识",
            "items": { "type": "string" }
          },
          "allowed_assumptions": {
            "type": "array",
            "description": "在证据不足时仍允许采用的显式假设（需写明边界；无则 []）",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "object",
            "properties": {
              "keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "min_length": { "type": "integer" },
              "logic_check": { "type": "string" }
            },
            "required": ["keywords", "logic_check"]
          }
        },
        "required": [
          "step_id",
          "name",
          "instruction",
          "dependencies",
          "risk_item",
          "fallback_strategy",
          "required_slots",
          "preferred_tools",
          "must_verify_facts",
          "allowed_assumptions",
          "fallback_when_missing",
          "acceptance_criteria"
        ]
      }
    }
  },
  "required": ["plan_summary", "steps"],
  "additionalProperties": true
}
