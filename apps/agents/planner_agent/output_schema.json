{
  "type": "object",
  "properties": {
    "plan_summary": {
      "type": "string",
      "description": "用一句话概括整个计划的逻辑流"
    },
    "steps": {
      "type": "array",
      "description": "3-7 个原子化执行步骤",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "step_id": { "type": "integer" },
          "name": { "type": "string" },
          "instruction": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "risk_item": { "type": "string" },
          "fallback_strategy": { "type": "string" },
          "acceptance_criteria": {
            "type": "object",
            "properties": {
              "keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "min_length": { "type": "integer" },
              "logic_check": { "type": "string" }
            },
            "required": ["keywords", "logic_check"]
          }
        },
        "required": [
          "step_id",
          "name",
          "instruction",
          "dependencies",
          "risk_item",
          "fallback_strategy",
          "acceptance_criteria"
        ]
      }
    }
  },
  "required": ["plan_summary", "steps"],
  "additionalProperties": true
}
