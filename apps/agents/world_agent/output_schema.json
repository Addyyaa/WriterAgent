{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "world_logic_summary": { "type": "string", "deprecated": true },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_type": { "type": "string" },
          "rule_description": { "type": "string" },
          "limitation": { "type": "string" }
        },
        "required": ["rule_type", "rule_description", "limitation"]
      }
    },
    "reusable_assets": {
      "type": "object",
      "properties": {
        "locations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "factions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "items_concepts": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["locations", "factions", "items_concepts"]
    },
    "potential_conflicts": {
      "type": "array",
      "deprecated": true,
      "items": {
        "type": "object",
        "properties": {
          "risk_scenario": { "type": "string" },
          "prevention_guide": { "type": "string" }
        },
        "required": ["risk_scenario", "prevention_guide"]
      }
    }
  },
  "required": ["hard_constraints", "reusable_assets"],
  "additionalProperties": true
}
