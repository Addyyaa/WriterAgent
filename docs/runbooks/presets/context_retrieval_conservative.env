# Conservative preset: quality-first, low-noise
WRITER_MEMORY_CONTEXT_TOKEN_BUDGET_DEFAULT=1200
WRITER_MEMORY_CONTEXT_MIN_RELEVANCE_SCORE=0.66
WRITER_MEMORY_CONTEXT_RELATIVE_SCORE_FLOOR=0.82
WRITER_MEMORY_CONTEXT_MIN_KEEP_ROWS=2
WRITER_MEMORY_CONTEXT_MAX_ROWS=20

# Retrieval loop control
WRITER_RETRIEVAL_ROUND_TOP_K=6
WRITER_RETRIEVAL_MAX_UNIQUE_EVIDENCE=48
WRITER_RETRIEVAL_STOP_MIN_COVERAGE=0.88
WRITER_RETRIEVAL_STOP_MIN_GAIN=0.06
WRITER_RETRIEVAL_STOP_STALE_ROUNDS=2

