{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agents/agent_strategy.schema.json",
  "title": "AgentStrategy",
  "type": "object",
  "required": ["version", "temperature", "max_tokens"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "temperature": {"type": "number"},
    "max_tokens": {"type": "integer", "minimum": 1},
    "style": {"type": "string"},
    "mode": {"type": "string"},
    "mode_strategies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "temperature": {"type": "number"},
          "max_tokens": {"type": "integer", "minimum": 1},
          "style": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
